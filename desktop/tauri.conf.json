{
  "productName": "NotifyHub Client",
  "version": "0.2.0",
  "identifier": "com.notifyhub.client",
  "build": {
    "frontendDist": "ui/dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "cd ../ui && npm run dev -- --port 1420",
    "beforeBuildCommand": "cd ../ui && npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "NotifyHub Desktop",
        "width": 1080,
        "height": 850,
        "resizable": true,
        "visible": true,
        "decorations": false,
        "transparent": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ]
  }
}
