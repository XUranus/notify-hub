{
  "productName": "NotifyHub Client",
  "version": "0.6.1",
  "identifier": "com.notifyhub.client",
  "build": {
    "frontendDist": "ui/dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "node ./node_modules/vite/bin/vite.js --port 1420",
    "beforeBuildCommand": "node ./node_modules/vite/bin/vite.js build"
  },
  "app": {
    "windows": [
      {
        "title": "NotifyHub Desktop",
        "width": 450,
        "height": 900,
        "resizable": false,
        "visible": false,
        "decorations": false,
        "transparent": true,
        "center": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ]
  }
}
