{
  "productName": "NotifyHub Client",
  "version": "0.1.0",
  "identifier": "com.notifyhub.client",
  "build": {
    "frontendDist": "./ui"
  },
  "app": {
    "windows": [
      {
        "title": "NotifyHub Desktop",
        "width": 1080,
        "height": 850,
        "resizable": true,
        "visible": true,
        "decorations": false,
        "transparent": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ]
  }
}
