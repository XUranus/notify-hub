{
  "name": "notify-hub",
  "version": "0.1.0",
  "private": true,
  "description": "Self-hosted notification push service",
  "scripts": {
    "dev": "pnpm --filter @notify-hub/server dev",
    "dev:web": "pnpm --filter @notify-hub/web dev",
    "build": "pnpm -r build",
    "build:server": "pnpm --filter @notify-hub/server build",
    "build:web": "pnpm --filter @notify-hub/web build",
    "build:cli": "pnpm --filter @notify-hub/cli build",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "pnpm@9.0.0"
}
